<%= turbo_frame_tag "options_frame_new" do %>
  <%= form_for @template_option, url: admin_template_options_path(@template), html: {class: "mt-4 sm:flex sm:items-center"} do |form| %>
    <%= form.label :name, class: "block pr-3 text-sm/6 font-medium text-gray-900 dark:text-white" %>
    <div class="w-full">
      <%= form.text_field :name, autocomplete: "name", placeholder: "user_input", class: "block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6 dark:bg-white/5 dark:text-white dark:outline-white/10 dark:placeholder:text-gray-500 dark:focus:outline-indigo-500" %>
    </div>
    <%= form.submit "Create", class: "rounded-md bg-indigo-600 ml-3 px-3 py-2 text-sm font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600 dark:bg-indigo-500 dark:shadow-none dark:hover:bg-indigo-400 dark:focus-visible:outline-indigo-500" %>
  <% end %>
<% end %>
