<div class="md:flex md:items-center md:justify-between">
  <div class="min-w-0 flex-1">
    <h2 class="text-2xl/7 font-bold text-gray-900 sm:truncate sm:text-3xl sm:tracking-tight dark:text-white">Crab Engines</h2>
  </div>
</div>

<div class="divide-y divide-gray-200 dark:divide-white/10">
  <div class="grid max-w-7xl grid-cols-1 gap-x-8 gap-y-10 py-16 md:grid-cols-3">
    <div>
      <h2 class="text-base/7 font-semibold text-gray-900 dark:text-white">New Engine</h2>
      <p class="mt-1 text-sm/6 text-gray-500 dark:text-gray-400">Engine options for the new engine</p>
    </div>

    <%= form_for @engine, url: admin_engines_path(@engine), html: {class: "md:col-span-2"} do |form| %>
      <div class="grid grid-cols-1 gap-x-6 gap-y-8 sm:max-w-xl sm:grid-cols-6">
        <div class="sm:col-span-full">
          <%= form.label :name, class: css_label %>
          <div class="mt-2">
            <%= form.text_field :name, autocomplete: "name", autofocus: true, class: css_text %>
          </div>
          <%= form.error_message(:name) %>
        </div>

        <div class="sm:col-span-full">
          <%= form.label :deploy_command, class: css_label %>
          <div class="mt-2">
            <%= form.text_field :deploy_command, autocomplete: "name", class: css_text %>
          </div>
          <%= form.error_message(:deploy_command) %>
        </div>

        <div class="sm:col-span-full">
          <%= form.label :status_command, class: css_label %>
          <div class="mt-2">
            <%= form.text_field :status_command, autocomplete: "name", class: css_text %>
          </div>
          <%= form.error_message(:status_command) %>
        </div>

        <div class="sm:col-span-full">
          <%= form.label :upgrade_command, class: css_label %>
          <div class="mt-2">
            <%= form.text_field :upgrade_command, autocomplete: "name", class: css_text %>
          </div>
          <%= form.error_message(:upgrade_command) %>
        </div>

        <div class="sm:col-span-full">
          <%= form.label :restart_command, class: css_label %>
          <div class="mt-2">
            <%= form.text_field :restart_command, autocomplete: "name", class: css_text %>
          </div>
          <%= form.error_message(:restart_command) %>
        </div>

        <div class="sm:col-span-full">
          <%= form.label :destroy_command, class: css_label %>
          <div class="mt-2">
            <%= form.text_field :destroy_command, autocomplete: "name", class: css_text %>
          </div>
          <%= form.error_message(:destroy_command) %>
        </div>
      </div>

      <div class="mt-8 flex">
        <%= form.submit "Create", class: css_button %>
      </div>
    <% end %>
  </div>
</div>
